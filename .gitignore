# 敏感文件 - 绝对不要提交
*.env
.env.*
*.pem
*.key
*_key
*_secret
credentials.json
secrets.json
token.json

# 可能包含敏感信息的目录
.secrets/
secrets/
private/

# 日志和缓存
*.log
*.cache

# 系统文件
.DS_Store
Thumbs.db

# 只允许以下文件类型提交：
# - memory/ 目录
# - .gitignore
# - .openclaw/
# - *.md 文件
# 其他所有文件都忽略

# 忽略所有文件
/*

# 允许的文件和目录
!/memory/
!/.gitignore
!/.openclaw/
!/*.md
!/.git/

# 允许 memory 目录内容
!/memory/**